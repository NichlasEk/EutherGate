[Unit]
Description=EutherGate reverse tunnel to EutherOxide
After=network-online.target euthergate.service
Wants=network-online.target euthergate.service

[Service]
Type=simple
ExecStart=/usr/bin/ssh -F /dev/null -N -T -o BatchMode=yes -o IdentitiesOnly=yes -o ExitOnForwardFailure=yes -o ServerAliveInterval=15 -o ServerAliveCountMax=3 -i %h/.ssh/euthersight_tunnel -R 127.0.0.1:18787:127.0.0.1:8787 nichlas@192.168.32.186
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
