EUTHERGATE_TOKEN=change-this-before-sharing-the-gate
EUTHERGATE_BIND=127.0.0.1:8787
EUTHERGATE_SECURE_COOKIE=false
# Shared only with the EutherOxide admin proxy. Generate a long random value.
EUTHERGATE_PROXY_TOKEN=
# Comma-separated TURN URLs. Set both values to enable corporate-network relay.
# EUTHERGATE_TURN_URLS=turns:turn.example.com:443?transport=tcp,turn:turn.example.com:3478?transport=udp
# Shared with coturn's static-auth-secret; never expose this value in client code.
# EUTHERGATE_TURN_SHARED_SECRET=
EUTHERGATE_DESKTOP_OUTPUT=EUTHERGATE-1
EUTHERGATE_DESKTOP_MODE=1280x720@30
# Normally discovered from $XDG_RUNTIME_DIR; override only for custom service layouts.
# EUTHERGATE_FORGE_SESSION_FILE=/run/user/1000/euthergate-forge/session.env
RUST_LOG=euthergate=info,tower_http=info
